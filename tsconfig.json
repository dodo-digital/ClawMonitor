{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "build",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/__tests__/**/*.ts"]
}
