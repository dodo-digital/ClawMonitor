# OpenClaw Gateway connection
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_WS=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# OpenClaw data directories
OPENCLAW_HOME=/path/to/.openclaw
OPENCLAW_WORKSPACE=/path/to/.openclaw/workspace

# Dashboard server
PORT=18801

# Monitor mode: "digest" (daily summary) or "realtime" (immediate alerts)
OPENCLAW_MONITOR_MODE=digest
OPENCLAW_MONITOR_DIGEST_HOUR=8

# Telegram notifications (optional)
OPENCLAW_MONITOR_TELEGRAM_BOT_TOKEN=
OPENCLAW_MONITOR_TELEGRAM_CHAT_ID=
OPENCLAW_MONITOR_TELEGRAM_TOPIC_ID=

# Slack notifications (optional)
OPENCLAW_MONITOR_SLACK_WEBHOOK_URL=

# Email notifications (optional)
OPENCLAW_MONITOR_EMAIL_ENDPOINT=
OPENCLAW_MONITOR_EMAIL_API_KEY=
OPENCLAW_MONITOR_EMAIL_FROM=
OPENCLAW_MONITOR_EMAIL_TO=

# Webhook notifications (optional)
OPENCLAW_MONITOR_WEBHOOK_URL=
OPENCLAW_MONITOR_WEBHOOK_SECRET=
